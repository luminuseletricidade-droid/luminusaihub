
# Backend Environment Variables
# Copy this file to .env and fill with your actual values

# OpenAI Configuration (Required for AI features)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Gemini Configuration (Optional for vision features)
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Logging Configuration
LOG_LEVEL=INFO

# File Processing Configuration
MAX_FILE_SIZE_MB=10

# CORS Configuration (update for production)
CORS_ORIGINS=["https://luminus.trustyu.com.br", "http://localhost:5173", "http://localhost:3000"]

# Security Configuration (generate strong keys for production)
# JWT_SECRET_KEY=generate-a-strong-secret-key-here
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Configuration (REQUIRED)
# Supabase PostgreSQL connection string
# Format: postgresql://postgres.[project-ref]:[password]@[host]:5432/postgres
SUPABASE_DB_URL=postgresql://user:password@host:port/database

# Environment selection (production | staging | development)
ENVIRONMENT=production

# Schema controls
SUPABASE_DB_SCHEMA=public
SUPABASE_STAGING_SCHEMA=staging

# Optional: Redis Configuration (for caching)
# REDIS_URL=redis://localhost:6379

# Optional: System Configuration
SYSTEM_NAME=Luminos Agno AI System
SYSTEM_VERSION=2.0.0
