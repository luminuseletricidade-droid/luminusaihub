# Frontend Environment Variables
# Copy this file to .env and fill with your actual values

# Supabase Configuration (Required)
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_SUPABASE_URL=https://your_project.supabase.co

# Backend API Configuration
# IMPORTANT: Keep this in sync with BACKEND_PORT in Makefile (default: 8001)
VITE_API_URL=http://localhost:8001

# Optional: Environment Configuration
# VITE_APP_ENV=development
# VITE_ENVIRONMENT=development
# VITE_ENABLE_DEBUG=false
# VITE_SENTRY_DSN=your_sentry_dsn_here

# Timezone Configuration
# Define o timezone padrão do sistema (default: America/Sao_Paulo)
# Timezones suportados:
# - America/Sao_Paulo (UTC-3) - Horário de Brasília (Padrão)
# - America/Manaus (UTC-4)
# - America/Rio_Branco (UTC-5)
# - America/Noronha (UTC-2)
# - America/Fortaleza, America/Recife, America/Belem, America/Maceio (UTC-3)
# VITE_TIMEZONE=America/Sao_Paulo

# Optional: Schema Overrides
# VITE_SUPABASE_SCHEMA=public
# VITE_SUPABASE_STAGING_SCHEMA=staging
# Optional: Storage Overrides
# VITE_SUPABASE_CONTRACTS_BUCKET=contract-documents
# VITE_SUPABASE_CONTRACTS_STAGING_BUCKET=contract-documents-staging

# Debug and Logging Configuration
# VITE_ENABLE_DEBUG=true
# VITE_LOG_LEVEL=debug
# VITE_LOG_TO_CONSOLE=true
# VITE_LOG_TO_STORAGE=true
# VITE_LOG_TO_BACKEND=false

# Sentry Configuration (optional)
# VITE_SENTRY_DSN=your_sentry_dsn

# Logging Levels:
# - debug: All logs (most verbose)
# - info: Info, warn, and error logs
# - warn: Warning and error logs only
# - error: Error logs only (least verbose)

# Logging Destinations:
# - VITE_LOG_TO_CONSOLE: Show logs in browser console (true/false)
# - VITE_LOG_TO_STORAGE: Store logs in localStorage (true/false)
# - VITE_LOG_TO_BACKEND: Send logs to backend (true/false)

# Development vs Production:
# In development: Set VITE_LOG_LEVEL=debug for maximum visibility
# In production: Set VITE_LOG_LEVEL=error for minimal logging

# Environment Configuration for Luminus AI Hub
# Copy this file to .env.local and adjust values as needed
